{
    "model": "GeneralMLP",
    "model_params": {
        "kwargs": {
            "input_size": 784,
            "hidden_size": 784,
            "num_classes": 10,
            "depth": 4,
            "activation_name": "tanh",
            "bias": false
        }
    },
    "optimizer": "SGD",
    "optimizer_params": {
        "lr": 0.001,
        "momentum": 0.0,
        "weight_decay": 0.0
    },
    "hyperparams": {
        "epochs": 150,
        "seed": 1,
        "log_freq": 10,
        "device": "cuda",
        "save_weights_history": true
    },
    "data_config": {
        "dataset_name": "MNIST",
        "batch_size": 128,
        "use_gpu": true,
        "fast_load": true,
        "transforms": [
            {
                "ToTensor": null
            },
            {
                "Normalize": {
                    "mean": [
                        0.1307
                    ],
                    "std": [
                        0.3081
                    ]
                }
            }
        ],
        "transform": "Compose(\n    ToTensor()\n    Normalize(mean=[0.1307], std=[0.3081])\n)"
    },
    "seed": 2
}